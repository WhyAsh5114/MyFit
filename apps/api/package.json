{
	"name": "@myfit/api",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/app.ts"
		},
		"./prisma/client": "./src/prisma-types.ts",
		"./prisma-idb/client": "./generated/prisma-idb/client/index.ts",
		"./prisma-idb/server": "./generated/prisma-idb/server/index.ts",
		"./validators": "./generated/prisma-idb/validators.ts",
		"./constants": "./lib/constants.ts",
		"./enums": "./generated/prisma-idb/enums.ts"
	},
	"scripts": {
		"dev": "bun --watch run src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target bun",
		"start": "bun dist/index.js",
		"generate": "prisma generate --sql",
		"push": "prisma db push",
		"studio": "prisma studio",
		"seed:off": "bun run prisma/seed/open-food-facts/main.ts",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"dependencies": {
		"@hono/zod-validator": "^0.7.6",
		"@prisma-idb/idb-client-generator": "^0.38.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"better-auth": "^1.6.9",
		"dotenv": "^17.4.2",
		"hono": "^4.12.17",
		"idb": "^8.0.3",
		"resend": "^6.12.2",
		"uuid": "^14.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/pg": "^8.20.0",
		"@types/pg-copy-streams": "^1.2.5",
		"chalk": "^5.6.2",
		"csv-parse": "^6.2.1",
		"pg": "^8.20.0",
		"pg-copy-streams": "^7.0.0",
		"prisma": "^7.8.0",
		"typescript": "^6.0.3"
	}
}
